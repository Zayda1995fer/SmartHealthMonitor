<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@drawable/heart_pulse_svg_"
        android:label="@string/app_name"
        android:roundIcon="@drawable/heart_pulse_svg_"
        android:supportsRtl="true"
        android:theme="@style/Theme.SmartHealthMonitor">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.SmartHealthMonitor">

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

        </activity>

        <!-- Wearable Data Layer Service -->
        <service
            android:name=".data.WearListenerService"
            android:exported="true">

            <intent-filter>

                <action
                    android:name="com.google.android.gms.wearable.MESSAGE_RECEIVED" />

                <data
                    android:scheme="wear"
                    android:host="*"
                    android:pathPrefix="/smarthealthmonitor" />

            </intent-filter>

        </service>

    </application>

</manifest>